{
  "cli": {
    "version": ">= 18.0.0",
    "appVersionSource": "local"
  },
  "build": {
    "preview": {
      "developmentClient": false,
      "distribution": "internal"
    },
    "production": {
      "autoIncrement": true
    },
    "android-apk": {
      "extends": "preview",
      "android": {
        "buildType": "apk"
      }
    },
    "ios-release": {
      "extends": "preview",
      "ios": {
        "simulator": false
      }
    },
    "ios-store": {
      "extends": "production",
      "distribution": "store",
      "autoIncrement": false,
      "ios": {
        "simulator": false
      }
    }
  },
  "submit": {
    "production": {}
  }
}
