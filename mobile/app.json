{
  "expo": {
    "name": "Volunteer Connect",
    "slug": "volunteer-connect",
    "version": "1.0.1",
    "sdkVersion": "54.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#1e3a8a"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.volunteerconnect.app",
      "buildNumber": "9",
      "infoPlist": {
        "NSCameraUsageDescription": "Allow VolunteerConnect to access your camera to set your profile picture.",
        "NSPhotoLibraryUsageDescription": "Allow VolunteerConnect to access photos and media on your device to set your profile picture.",
        "NSLocationWhenInUseUsageDescription": "Your location is used to show nearby volunteers and events.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "icon": "./assets/icon.png",
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.volunteerconnectone.app",
      "versionCode": 10,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_EXTERNAL_STORAGE"
      ]
    },
    "scheme": "volunteerconnect",
    "plugins": [
      "@react-native-community/datetimepicker",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Your location is used to show nearby volunteers and events."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow VolunteerConnect to access photos and media on your device to set your profile picture.",
          "cameraPermission": "Allow VolunteerConnect to access your camera to set your profile picture."
        }
      ]
    ],
    "extra": {
      "apiUrl": "https://volunteerconnect.cloud/api",
      "eas": {
        "projectId": "55332645-ee23-4454-8e78-f87af83b8d0b"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/c647c77f-5705-49c1-9be9-b62ea985f1db"
    },
    "owner": "umashankars1"
  }
}
