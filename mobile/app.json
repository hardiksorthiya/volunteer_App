{
  "expo": {
    "name": "Volunteer Connect",
    "slug": "volunteer-connect",
    "version": "1.0.0",
    "sdkVersion": "54.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#1e3a8a"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.volunteerconnect.app",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/logo.png",
        "backgroundColor": "#1e3a8a"
      },
      "package": "com.volunteerconnect.app",
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "scheme": "volunteerconnect",
    "plugins": [
      "@react-native-community/datetimepicker",
      "expo-location"
    ],
    "extra": {
      "apiUrl": "https://volunteerconnect.cloud/api",
      "eas": {
        "projectId": "55332645-ee23-4454-8e78-f87af83b8d0b"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/c647c77f-5705-49c1-9be9-b62ea985f1db"
    },
    "owner": "umashankars1"
  }
}
