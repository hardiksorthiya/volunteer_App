{
  "expo": {
    "name": "Volunteer Connect",
    "slug": "volunteer-connect",
    "version": "1.0.0",
    "sdkVersion": "54.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "icon": "./assets/icon.png",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#2563eb",
      "image": "./assets/splash.png"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.volunteerconnect.app"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#2563eb",
        "foregroundImage": "./assets/icon.png"
      },
      "package": "com.volunteerconnect.app"
    },
    "scheme": "volunteerconnect",
    "plugins": [
      "@react-native-community/datetimepicker"
    ],
    "extra": {
      "apiUrl": "https://volunteerconnect.io/api",
      "eas": {
        "projectId": "volunteer-connect"
      }
    }
  }
}
