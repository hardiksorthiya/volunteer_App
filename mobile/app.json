{
  "expo": {
    "name": "Volunteer Connect",
    "slug": "volunteer-connect",
    "version": "1.0.0",
    "sdkVersion": "54.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#2563eb"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.volunteerconnect.app",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#2563eb"
      },
      "package": "com.volunteerconnect.app"
    },
    "scheme": "volunteerconnect",
    "plugins": [
      "@react-native-community/datetimepicker"
    ],
    "extra": {
      "apiUrl": "https://volunteerconnect.cloud/api",
      "eas": {
        "projectId": "c647c77f-5705-49c1-9be9-b62ea985f1db"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/c647c77f-5705-49c1-9be9-b62ea985f1db"
    }
  }
}
